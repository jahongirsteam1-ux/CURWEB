{
  "name": "curweb-backend",
  "version": "1.0.0",
  "description": "CurWeb Gesture & Voice Controlled Mini App Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:generate": "prisma generate --schema=src/db/schema.prisma",
    "db:push": "prisma db push --schema=src/db/schema.prisma",
    "db:studio": "prisma studio --schema=src/db/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.12.1"
  }
}
